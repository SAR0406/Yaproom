# Environment Variables Template
# Copy this file to .env.local and fill in your values

# ============================================================================
# BACKEND CONFIGURATION
# ============================================================================

# Node environment (development, staging, production)
NODE_ENV=development

# Server port
PORT=3000

# Database connection
DATABASE_URL=postgresql://user:password@localhost:5432/yaproom

# Redis connection (optional, for caching and scaling)
REDIS_URL=redis://localhost:6379

# ============================================================================
# SECURITY
# ============================================================================

# JWT secret for session tokens
JWT_SECRET=your-secret-key-change-this-in-production

# API keys for external services
API_KEY_STRIPE=sk_test_...
API_KEY_SENDGRID=SG.xxx...

# ============================================================================
# CORS & ALLOWED ORIGINS
# ============================================================================

# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000,https://yaproom.com,https://www.yaproom.com

# Socket.io CORS
SOCKET_CORS_ORIGIN=http://localhost:3001

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:3000

# WebSocket URL
NEXT_PUBLIC_WS_URL=ws://localhost:3000

# Frontend port (development only)
PORT_WEB=3001

# ============================================================================
# LOGGING & MONITORING
# ============================================================================

# Log level (error, warn, info, debug, trace)
LOG_LEVEL=info

# Sentry error tracking (optional)
SENTRY_DSN=

# New Relic monitoring (optional)
NEW_RELIC_LICENSE_KEY=

# DataDog APM (optional)
DATADOG_API_KEY=

# ============================================================================
# GAME CONFIGURATION
# ============================================================================

# Min/max players per game
GAME_MIN_PLAYERS=3
GAME_MAX_PLAYERS=20

# Game timeouts (milliseconds)
GAME_TIMEOUT_LOBBY=0
GAME_TIMEOUT_SETUP=2000
GAME_TIMEOUT_ROUND_START=3000
GAME_TIMEOUT_PLAYER_ACTION=120000
GAME_TIMEOUT_VOTING=60000
GAME_TIMEOUT_REVEAL=10000
GAME_TIMEOUT_SCORING=5000
GAME_TIMEOUT_NEXT_ROUND=3000
GAME_TIMEOUT_MATCH_END=10000

# Room settings
ROOM_MAX_PLAYERS=20
ROOM_EXPIRY_HOURS=24
RECONNECT_WINDOW_MS=30000

# ============================================================================
# DATABASE SETTINGS
# ============================================================================

# Connection pool size
DB_POOL_MIN=2
DB_POOL_MAX=20

# Connection timeout
DB_CONNECT_TIMEOUT=5000

# Query timeout
DB_QUERY_TIMEOUT=30000

# ============================================================================
# CACHE SETTINGS (if using Redis)
# ============================================================================

# Cache TTL (seconds)
CACHE_TTL_ROOMS=300
CACHE_TTL_PLAYERS=600
CACHE_TTL_PROMPTS=86400

# ============================================================================
# RATE LIMITING
# ============================================================================

# Max actions per second per player
RATE_LIMIT_ACTIONS_PER_SEC=10

# Max API requests per minute per IP
RATE_LIMIT_API_PER_MIN=60

# Max socket events per second per player
RATE_LIMIT_SOCKET_EVENTS=20

# ============================================================================
# CONTENT MODERATION
# ============================================================================

# Enable content moderation
CONTENT_MODERATION_ENABLED=false

# Banned words list (comma-separated)
BANNED_WORDS=

# ============================================================================
# EMAIL CONFIGURATION (optional)
# ============================================================================

# SMTP settings for notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-password
SMTP_FROM=noreply@yaproom.com

# SendGrid (alternative to SMTP)
SENDGRID_API_KEY=SG.xxx...

# ============================================================================
# STORAGE CONFIGURATION
# ============================================================================

# AWS S3 for drawings/exports
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=yaproom-files

# Or use local storage
STORAGE_TYPE=local  # local or s3

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable/disable games
FEATURE_UNDERCOVER_ENABLED=true
FEATURE_DRAWING_ENABLED=true
FEATURE_QUIPLASH_ENABLED=true
FEATURE_CODENAMES_ENABLED=true
FEATURE_CONFESSION_ENABLED=true

# Enable/disable features
FEATURE_SPECTATOR_MODE_ENABLED=true
FEATURE_CHAT_ENABLED=false
FEATURE_VOICE_ENABLED=false
FEATURE_VIDEO_ENABLED=false
FEATURE_REPLAY_ENABLED=false
FEATURE_LEADERBOARD_ENABLED=true

# ============================================================================
# DEVELOPMENT SETTINGS
# ============================================================================

# Enable debug logging
DEBUG=false

# Enable mock data
MOCK_DATA_ENABLED=false

# Enable API documentation
API_DOCS_ENABLED=true

# Hot reload
HOT_RELOAD=true

# ============================================================================
# PRODUCTION SETTINGS
# ============================================================================

# SSL/TLS
SSL_ENABLED=true
SSL_CERT_PATH=/etc/letsencrypt/live/yaproom.com/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/yaproom.com/privkey.pem

# Compression
COMPRESSION_ENABLED=true

# CDN URL (for static assets)
CDN_URL=https://cdn.yaproom.com

# ============================================================================
# ANALYTICS
# ============================================================================

# Google Analytics
GOOGLE_ANALYTICS_ID=

# Amplitude
AMPLITUDE_API_KEY=

# Mixpanel
MIXPANEL_TOKEN=

# ============================================================================
# INTEGRATIONS
# ============================================================================

# Stripe (for payments)
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Discord webhook (for notifications)
DISCORD_WEBHOOK_URL=

# Slack webhook (for alerts)
SLACK_WEBHOOK_URL=

# ============================================================================
# DOCUMENTATION
# ============================================================================

# API Documentation
API_DOCS_URL=http://localhost:3000/api/docs

# Swagger UI
SWAGGER_ENABLED=true

# ============================================================================
# NOTES
# ============================================================================

# For development:
#   1. Copy .env.example to .env.local
#   2. Update values as needed
#   3. Never commit .env.local to git
#   4. Use same for local frontend and backend
#
# For production:
#   1. Use environment variables from your deployment platform
#   2. Use secrets manager (AWS Secrets Manager, HashiCorp Vault, etc.)
#   3. Never hardcode secrets
#   4. Rotate keys regularly
#
# For Docker:
#   1. Pass as environment variables: docker run -e DATABASE_URL=...
#   2. Or use .env file: docker run --env-file .env.production
#
# Testing:
#   1. Use separate test database
#   2. Set NODE_ENV=test
#   3. Don't use production secrets
